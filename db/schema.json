{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plupdate.dev/schema/vendor.json",
  "title": "Plupdate Vendor File",
  "description": "One file per vendor under vendors/<slug>.json. Slug must match filename.",
  "type": "object",
  "additionalProperties": false,
  "required": ["vendor", "trustedDomain", "plugins"],
  "properties": {
    "vendor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Display name of the vendor."
    },
    "homepage": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Vendor's homepage. Optional but recommended."
    },
    "trustedDomain": {
      "$ref": "#/$defs/domain",
      "description": "Canonical registrable domain for the vendor (e.g. 'klevgrand.com'). Every vendorPage host MUST equal this or be a subdomain. Every downloadURL host MUST equal this, be a subdomain, or appear in allowedDownloadHosts."
    },
    "allowedDownloadHosts": {
      "type": ["array", "null"],
      "description": "Exact hostnames (not subdomains) that may serve downloadURLs in addition to trustedDomain. Use for legitimate CDN/object-store hosts (e.g. 'vendor.ams3.cdn.digitaloceanspaces.com'). Reviewed manually before merge.",
      "items": { "$ref": "#/$defs/host" },
      "uniqueItems": true,
      "maxItems": 20
    },
    "signingTeamId": {
      "type": ["string", "null"],
      "pattern": "^[A-Z0-9]{10}$",
      "description": "Apple Developer Team ID expected to sign every plugin from this vendor (10 uppercase alphanumeric chars). When present, the app verifies the installed plugin's code signature and warns on mismatch. Maintainer-curated; do not set unless you've inspected an installed binary."
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/plugin" }
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundleId", "name", "latestVersion"],
      "properties": {
        "bundleId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]+$",
          "minLength": 3,
          "maxLength": 200,
          "description": "AAX bundle identifier as found in Info.plist (CFBundleIdentifier)."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "latestVersion": {
          "type": "string",
          "pattern": "^[0-9][0-9A-Za-z._-]*$",
          "minLength": 1,
          "maxLength": 80
        },
        "vendorPage": {
          "type": ["string", "null"],
          "format": "uri",
          "maxLength": 500
        },
        "downloadURL": {
          "type": ["string", "null"],
          "format": "uri",
          "maxLength": 500
        },
        "notes": {
          "type": ["string", "null"],
          "maxLength": 2000
        },
        "drm": {
          "type": ["array", "null"],
          "description": "Authorization methods accepted by this plugin. Multiple entries mean the plugin accepts any of them.",
          "items": { "$ref": "#/$defs/drmMethod" }
        }
      }
    },
    "domain": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)+$",
      "minLength": 4,
      "maxLength": 253
    },
    "host": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)+$",
      "minLength": 4,
      "maxLength": 253
    },
    "drmMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["ilok", "authfile", "serial", "login", "custom"]
        },
        "paths": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "notes": {
          "type": ["string", "null"],
          "maxLength": 500
        }
      }
    }
  }
}
